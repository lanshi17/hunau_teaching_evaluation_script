# 湖南农业大学 WebVPN 登录账号
# 填写账号密码可走自动登录；留空则使用二维码登录
HUNAU_USERNAME="your_student_id"
HUNAU_PASSWORD="your_password"

# 浏览器无头模式：true / false；留空按环境自动判断
HUNAU_HEADLESS=

# chromedriver 路径（推荐绝对路径）；留空则从 PATH 查找
HUNAU_CHROMEDRIVER_PATH=/usr/local/bin/chromedriver

# 本地无 chromedriver 时是否自动下载：true / false
HUNAU_AUTO_INSTALL_DRIVER=true

# 浏览器代理（可选），例如：http://127.0.0.1:7890
HUNAU_WEBDRIVER_PROXY=

# LLM 主观题评价配置（不填 APIKEY 时自动使用静态评价库随机文案）
HUNAU_LLM_ENABLED=true
HUNAU_LLM_API_KEY=
HUNAU_LLM_BASE_URL=https://api.openai.com/v1
HUNAU_LLM_ENDPOINT=
HUNAU_LLM_MODEL=gpt-4o-mini
HUNAU_LLM_TIMEOUT=25
HUNAU_LLM_TEMPERATURE=0.7
HUNAU_LLM_MAX_TOKENS=180

# 主观题风格与提示词
HUNAU_REVIEW_STYLE=积极向上、真诚、专业
HUNAU_REVIEW_PROMPT="请围绕课程《{course_name}》和教师{teacher_name}生成一段{style}的课程评价意见，中文，不分点，15到25字，突出教学认真、内容扎实与学习收获。"
HUNAU_SUBJECTIVE_MAX_CHARS=25
